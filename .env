# -------------------------
# DATABASE CONFIGURATIONS
# -------------------------
# PostgreSQL Connection String (Used by User, Appointment, and Order services)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/happypaws_users

# MongoDB Connection String (Used by Pet service)
MONGO_URI=mongodb://localhost:27017/

# -------------------------
# SECURITY CONFIGURATIONS
# -------------------------
# Secret key for JWT Authentication
SECRET_KEY=your_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -------------------------
# SERVICE URLS (API GATEWAY)
# -------------------------
USER_SERVICE_URL=http://localhost:8001
PET_SERVICE_URL=http://localhost:8002
APPOINTMENT_SERVICE_URL=http://localhost:8003
ORDER_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005

# -------------------------
# FRONTEND CONFIGURATIONS
# -------------------------
# Vite Frontend uses variables prefixed with VITE_
VITE_API_GATEWAY_URL=http://localhost:8000
